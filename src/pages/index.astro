---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Services from '../components/Services.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import About from '../components/About.astro';
import Team from '../components/Team.astro';
import Clients from '../components/Clients.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('portfolio');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
  <Header />
  <Services />
  <PortfolioGrid posts={sortedPosts} />
  <About />
  <Team />
  <Clients />
  <Contact />
  <Footer />
  <Modals posts={sortedPosts} />
</Layout>
