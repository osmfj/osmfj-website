---
import { corporateMembers, infrastructureSponsors } from '../data/sponsors';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<!-- 協賛会員 -->
<aside class="py-5">
  <div class="container">
    <div class="col-lg-12 text-center">
      <h2 class="section-heading">企業賛助会員</h2>
    </div>
    <div class="row justify-content-center align-items-center">
      {corporateMembers.map((s) => (
        <div class="col-6 col-sm-4 col-lg-3 my-3">
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="sponsor-logo-link">
            <img src={`${base}img/logos/${s.logo}`} class="sponsor-logo" alt={s.name} />
          </a>
        </div>
      ))}
    </div>
    <div class="col-lg-12 text-center mt-4">
      <h2 class="section-heading">サーバインフラ支援</h2>
    </div>
    <div class="row justify-content-center align-items-center">
      {infrastructureSponsors.map((s) => (
        <div class="col-6 col-sm-4 col-lg-3 my-3">
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="sponsor-logo-link">
            <img src={`${base}img/logos/${s.logo}`} class="sponsor-logo" alt={s.name} />
          </a>
        </div>
      ))}
    </div>
  </div>
</aside>

<style>
  .sponsor-logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100px;
  }

  .sponsor-logo {
    max-height: 100px;
    max-width: 100%;
    width: auto;
    object-fit: contain;
  }
</style>