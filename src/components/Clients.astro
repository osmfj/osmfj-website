---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<!-- Clients -->
<aside class="py-5">
  <div class="container clients">
    <div class="col-lg-12 text-center">
      <h2 class="section-heading">企業賛助会員</h2>
    </div>
    <div class="row justify-content-center align-items-center">
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://www.mapquest.co.jp/">
          <img src={`${base}img/logos/mapquest.png`} class="img-fluid d-block mx-auto" alt="MapQuest" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="http://www.sw-factory.com/">
          <img src={`${base}img/logos/softwarefactory.png`} class="img-fluid d-block mx-auto" alt="Software Factory" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://geolonia.com/">
          <img src={`${base}img/logos/geolonia.png`} class="img-fluid d-block mx-auto" alt="Geolonia" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://www.mapbox.jp/">
          <img src={`${base}img/logos/mapbox.png`} class="img-fluid d-block mx-auto" alt="Mapbox" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://www.ic-inc.world/home">
          <img src={`${base}img/logos/iC_logo.jpg`} class="img-fluid d-block mx-auto" alt="iC" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://www.nttdata.com/jp/ja/">
          <img src={`${base}img/logos/nttdata.png`} class="img-fluid d-block mx-auto" alt="NTT Data" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://www.tomtom.com/">
          <img src={`${base}img/logos/TomTom-logo-RGB_lockup.png`} class="img-fluid d-block mx-auto" alt="TomTom" />
        </a>
      </div>
    </div>
    <div class="col-lg-12 text-center">
      <h2 class="section-heading">サーバインフラ支援</h2>
    </div>
    <div class="row justify-content-center align-items-center">
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://www.sakura.ad.jp/">
          <img src={`${base}img/logos/sakurainternet.png`} class="img-fluid d-block mx-auto" alt="さくらインターネット" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://www.onamae-server.com/">
          <img src={`${base}img/logos/gmologo.png`} class="img-fluid d-block mx-auto" alt="GMO" />
        </a>
      </div>
      <div class="col-md-6 col-sm-6 my-3">
        <a href="https://virtualtech.jp/">
          <img src={`${base}img/logos/vtj.png`} class="img-fluid d-block mx-auto" alt="VirtualTech Japan" />
        </a>
      </div>
    </div>
  </div>
</aside>
