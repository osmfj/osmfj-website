---
import type { CollectionEntry } from 'astro:content';
import Fee from './Fee.astro';

interface Props {
  posts: CollectionEntry<'organization'>[];
}

const { posts } = Astro.props;

const sortedPosts = [...posts].sort((a, b) => a.data.order - b.data.order);

const renderedPosts = await Promise.all(
  sortedPosts.map(async (post) => {
    const { Content } = await post.render();
    return { post, Content };
  })
);
---
<section class="page-section bg-light" id="organization">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="section-heading">OSMFJについて</h2>
    </div>
    <ul class="nav nav-tabs justify-content-center" id="orgTabs" role="tablist">
      {renderedPosts.map(({ post }, index) => (
        <li class="nav-item">
          <a
            class={`nav-link${index === 0 ? ' active' : ''}`}
            id={`org-tab-${post.slug}`}
            data-toggle="tab"
            href={`#org-panel-${post.slug}`}
            role="tab"
            aria-controls={`org-panel-${post.slug}`}
            aria-selected={index === 0 ? 'true' : 'false'}
          >
            {post.data.title}
          </a>
        </li>
      ))}
    </ul>
    <div class="tab-content pt-4" id="orgTabsContent">
      {renderedPosts.map(({ post, Content }, index) => (
        <div
          class={`tab-pane fade${index === 0 ? ' show active' : ''}`}
          id={`org-panel-${post.slug}`}
          role="tabpanel"
          aria-labelledby={`org-tab-${post.slug}`}
        >
          <Content />
          {post.data.category === 'kaihi' && <Fee />}
        </div>
      ))}
    </div>
  </div>
</section>